# OpenAI / LLM
OPENAI_API_KEY=coloque-sua-chave-openai-aqui
LLM_MODEL=gpt-4o-mini

# LangSmith opcional
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=coloque-sua-chave-langsmith-aqui
LANGSMITH_PROJECT=mba-ia-pull-evaluation-api

# Banco de dados
DATABASE_URL=sqlite:///./app.db

# Ambiente
ENVIRONMENT=development

# Admin local de desenvolvimento
# Em SQLite/local, o sistema pode criar automaticamente este usuário no startup.
# Em produção, defina CREATE_DEV_ADMIN=false.
CREATE_DEV_ADMIN=true
DEV_ADMIN_EMAIL=admin@exemplo.com
DEV_ADMIN_PASSWORD=123456
